<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<title>{{ t.cover_report_title }} — {{ scan.url }}</title>
<style>
  :root {
    --slate-950: #0b1220;
    --slate-900: #0f172a;
    --slate-800: #1e293b;
    --slate-700: #334155;
    --slate-500: #64748b;
    --slate-300: #cbd5e1;
    --slate-100: #f1f5f9;
    --slate-50: #f8fafc;
    --emerald: #10b981;
    --emerald-dark: #047857;
    --amber: #f59e0b;
    --red: #ef4444;
    --font: -apple-system, "Segoe UI", "Inter", Roboto, Helvetica, Arial, sans-serif;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    font-family: var(--font);
    color: var(--slate-800);
    background: var(--slate-50);
    font-size: 15px;
    line-height: 1.55;
  }
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 56px;
    background: #fff;
    page-break-after: always;
  }
  .page:last-child { page-break-after: auto; }

  /* ---------- Cover ---------- */
  .cover {
    background: linear-gradient(160deg, var(--slate-950) 0%, var(--slate-900) 60%, var(--slate-800) 100%);
    color: var(--slate-100);
    min-height: 1000px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .cover-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .brand-block { display: flex; align-items: center; gap: 12px; }
  .brand-logo { height: 40px; max-width: 160px; object-fit: contain; }
  .brand-name { font-weight: 600; font-size: 15px; color: var(--slate-100); }
  .tagline-pill {
    font-size: 12px; letter-spacing: .04em; text-transform: uppercase;
    color: var(--emerald); border: 1px solid rgba(16,185,129,.4);
    padding: 6px 12px; border-radius: 999px; background: rgba(16,185,129,.08);
  }
  .cover-title { font-size: 34px; font-weight: 700; margin: 28px 0 4px; color: #fff; }
  .cover-url { font-size: 16px; color: var(--slate-300); margin-bottom: 28px; word-break: break-all; }
  .cover-main { display: flex; gap: 32px; align-items: center; }
  .cover-screenshot-frame {
    flex: 0 0 240px; border-radius: 22px; border: 6px solid var(--slate-700);
    overflow: hidden; background: #000; box-shadow: 0 20px 50px rgba(0,0,0,.45);
  }
  .cover-screenshot-frame img { display: block; width: 100%; }
  .score-block { flex: 1; display: flex; flex-direction: column; gap: 18px; }
  .score-circle {
    width: 150px; height: 150px; border-radius: 50%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    border: 10px solid {{ grade_color }};
    background: rgba(255,255,255,.03);
  }
  .score-number { font-size: 42px; font-weight: 800; color: #fff; line-height: 1; }
  .score-label { font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: var(--slate-300); margin-top: 4px; }
  .grade-pill {
    display: inline-block; margin-top: 10px; font-weight: 700; font-size: 20px;
    color: {{ grade_color }};
  }
  .cover-meta { display: flex; gap: 40px; margin-top: 30px; font-size: 13px; color: var(--slate-300); }
  .cover-meta div span.label { display: block; text-transform: uppercase; font-size: 10.5px; letter-spacing: .06em; color: var(--slate-500); margin-bottom: 3px; }
  .cover-footer { font-size: 12px; color: var(--slate-500); margin-top: 24px; }

  /* ---------- Generic page chrome ---------- */
  h1.section-title { font-size: 22px; font-weight: 700; color: var(--slate-900); margin: 0 0 6px; }
  .eyebrow { font-size: 12px; text-transform: uppercase; letter-spacing: .06em; color: var(--emerald-dark); font-weight: 700; margin-bottom: 6px; }
  .intro-text { color: var(--slate-700); font-size: 15px; margin-bottom: 18px; }
  .summary-callout {
    background: var(--slate-900); color: #fff; border-radius: 14px;
    padding: 22px 26px; font-size: 17px; font-weight: 600; line-height: 1.4;
    margin: 20px 0 28px;
  }
  .summary-counts { display: flex; gap: 14px; margin-bottom: 10px; }
  .count-chip { border-radius: 10px; padding: 10px 16px; font-size: 13px; font-weight: 600; flex: 1; }
  .count-chip.critical { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
  .count-chip.warning { background: #fffbeb; color: #b45309; border: 1px solid #fde68a; }
  .count-chip.ok { background: #ecfdf5; color: #047857; border: 1px solid #a7f3d0; }
  .count-chip b { display: block; font-size: 20px; }

  /* ---------- Findings ---------- */
  .finding { margin-bottom: 30px; border: 1px solid var(--slate-100); border-radius: 14px; overflow: hidden; }
  .finding-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 22px; background: var(--slate-50); border-bottom: 1px solid var(--slate-100);
  }
  .finding-name { font-size: 17px; font-weight: 700; color: var(--slate-900); }
  .badge { font-size: 11.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; padding: 5px 12px; border-radius: 999px; }
  .badge.critical { background: #fef2f2; color: #b91c1c; }
  .badge.warning { background: #fffbeb; color: #b45309; }
  .badge.ok { background: #ecfdf5; color: #047857; }
  .finding-body { padding: 20px 22px; }
  .finding-block { margin-bottom: 16px; }
  .finding-block:last-child { margin-bottom: 0; }
  .finding-block-label { font-size: 11.5px; text-transform: uppercase; letter-spacing: .05em; color: var(--slate-500); font-weight: 700; margin-bottom: 6px; }
  .evidence-list { margin: 0; padding-left: 20px; color: var(--slate-700); }
  .evidence-list li { margin-bottom: 4px; }
  .impact-text { color: var(--slate-900); font-size: 15.5px; font-weight: 500; border-left: 3px solid {{ grade_color }}; padding-left: 14px; }
  .benefit-text { color: var(--emerald-dark); font-weight: 600; }
  .screens { display: flex; gap: 20px; margin-top: 14px; }
  .screen-col { flex: 1; text-align: center; }
  .screen-col .cap { font-size: 12px; color: var(--slate-500); margin-bottom: 8px; font-weight: 600; }
  .screen-col img { max-width: 100%; border-radius: 10px; border: 1px solid var(--slate-100); box-shadow: 0 6px 18px rgba(15,23,42,.08); }
  .screen-col.mobile img { max-height: 420px; }
  .screen-col.desktop img { max-height: 320px; }

  /* ---------- Next steps ---------- */
  .cta-page { background: var(--slate-900); color: #fff; min-height: 500px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
  .cta-heading { font-size: 36px; font-weight: 800; margin-bottom: 14px; }
  .cta-body { font-size: 16px; color: var(--slate-300); max-width: 560px; margin-bottom: 30px; }
  .cta-box { background: var(--emerald); color: #04231a; border-radius: 14px; padding: 40px 50px; max-width: 650px; text-align: center; }
  .cta-box .cta-line { font-size: 28px; font-weight: 700; margin-bottom: 20px; }
  .cta-box .cta-subline { font-size: 18px; font-weight: 600; }
  .cta-contacts { display: flex; gap: 26px; font-size: 14px; font-weight: 600; flex-wrap: wrap; justify-content: center; }

  /* ---------- Report footer actions ---------- */
  .report-footer { background: var(--slate-900); padding: 30px; text-align: center; display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .action-btn { background: var(--emerald); color: #04231a; border: none; padding: 12px 28px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; }
  .action-btn:hover { filter: brightness(1.08); }
  .action-btn.secondary { background: var(--slate-700); color: #fff; }
  .action-btn.secondary:hover { background: var(--slate-600); }

  @media print {
    body { background: #fff; }
    .page { box-shadow: none; }
    .report-footer { display: none; }
  }
</style>
</head>
<body>

  <section class="page cover">
    <div>
      <div class="cover-top">
        <div class="brand-block">
          {% if brand_logo_data_uri %}<img class="brand-logo" src="{{ brand_logo_data_uri }}" alt="{{ brand.name }}">{% endif %}
          <span class="brand-name">{{ brand.name }}</span>
        </div>
        <span class="tagline-pill">{{ t.tagline }}</span>
      </div>
      <div class="cover-title">{{ t.cover_report_title }}</div>
      <div class="cover-url">{{ scan.url }}</div>
      <div class="cover-main">
        <div class="cover-screenshot-frame">
          {% if cover_screenshot %}<img src="data:image/png;base64,{{ cover_screenshot }}" alt="Site screenshot">{% endif %}
        </div>
        <div class="score-block">
          <div class="score-circle">
            <div class="score-number">{{ score }}</div>
            <div class="score-label">{{ t.cover_health_score }} / 100</div>
          </div>
          <div class="grade-pill">{{ t.cover_grade }}: {{ grade }}</div>
        </div>
      </div>
    </div>
    <div>
      <div class="cover-meta">
        <div><span class="label">{{ t.cover_prepared_for }}</span>{{ scan.url }}</div>
        <div><span class="label">{{ t.cover_prepared_by }}</span>{{ brand.name }}</div>
        <div><span class="label">&nbsp;</span>{{ t.cover_scanned_on }}</div>
      </div>
      <div class="cover-footer">{{ t.footer_generated_by }}</div>
    </div>
  </section>

  <section class="page">
    <div class="eyebrow">{{ t.exec_summary_heading }}</div>
    <h1 class="section-title">{{ t.exec_summary_heading }}</h1>
    <p class="intro-text">{{ t.exec_summary_intro }}</p>
    <div class="summary-callout">{{ t.exec_summary_sentence }}</div>
    <div class="summary-counts">
      {% set crit = checks | selectattr('severity.value', 'equalto', 'critical') | list | length %}
      {% set warn = checks | selectattr('severity.value', 'equalto', 'warning') | list | length %}
      {% set ok = checks | selectattr('severity.value', 'equalto', 'ok') | list | length %}
      <div class="count-chip critical"><b>{{ crit }}</b>{{ t.severity_critical }}</div>
      <div class="count-chip warning"><b>{{ warn }}</b>{{ t.severity_warning }}</div>
      <div class="count-chip ok"><b>{{ ok }}</b>{{ t.severity_ok }}</div>
    </div>
  </section>

  {% for check in checks %}
  <section class="page">
    <div class="finding">
      <div class="finding-header">
        <span class="finding-name">{{ loop.index }}. {{ check.name }}</span>
        <span class="badge {{ check.severity.value }}">
          {% if check.severity.value == 'critical' %}{{ t.severity_critical }}
          {% elif check.severity.value == 'warning' %}{{ t.severity_warning }}
          {% else %}{{ t.severity_ok }}{% endif %}
        </span>
      </div>
      <div class="finding-body">
        <div class="finding-block">
          <div class="finding-block-label">{{ t.section_what_we_found }}</div>
          <ul class="evidence-list">
            {% for item in check.evidence %}<li>{{ item }}</li>{% endfor %}
          </ul>
          {% if check.screenshots %}
          <div class="screens">
            {% if check.screenshots|length > 0 %}
            <div class="screen-col mobile">
              <div class="cap">{{ t.section_mobile_view }}</div>
              <img src="data:image/png;base64,{{ check.screenshots[0] }}" alt="Mobile screenshot">
            </div>
            {% endif %}
            {% if check.screenshots|length > 1 %}
            <div class="screen-col desktop">
              <div class="cap">{{ t.section_desktop_view }}</div>
              <img src="data:image/png;base64,{{ check.screenshots[1] }}" alt="Desktop screenshot">
            </div>
            {% endif %}
          </div>
          {% endif %}
        </div>
        <div class="finding-block">
          <div class="finding-block-label">{{ t.section_why_it_matters }}</div>
          <div class="impact-text">{{ check.impact }}</div>
        </div>
        <div class="finding-block">
          <div class="finding-block-label">{{ t.section_what_you_get }}</div>
          <div class="benefit-text">{{ check.recommendation }}</div>
        </div>
      </div>
    </div>
  </section>
  {% endfor %}

  <section class="page cta-page">
    <div class="cta-heading">{{ t.next_steps_heading }}</div>
    <div class="cta-body">{{ t.next_steps_body }}</div>
    <a href="https://zerodigitx.com/contact" class="cta-box" style="display: block; text-decoration: none; color: inherit;">
      <p class="cta-line">Talk to Mario at Zero Digit X for updating your website</p>
    </a>
  </section>

  <div class="report-footer">
    <button class="action-btn" id="pdf-btn" onclick="generatePDF()">📄 Download as PDF</button>
    <button class="action-btn secondary" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">⬆ Back to Top</button>
  </div>

  <script>
    // Extract HTML filename from current page URL
    function getReportFilename() {
      const path = window.location.pathname;
      const match = path.match(/\/reports\/([^\/]+\.html)/);
      return match ? match[1] : null;
    }

    // Generate PDF and trigger download
    async function generatePDF() {
      const filename = getReportFilename();
      if (!filename) {
        alert('Could not determine report filename');
        return;
      }

      const btn = document.getElementById('pdf-btn');
      const originalText = btn.textContent;
      btn.textContent = '⏳ Generating PDF...';
      btn.disabled = true;

      try {
        const response = await fetch(`/reports/${filename}/generate-pdf`, {
          method: 'POST',
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'PDF generation failed');
        }

        // Download the PDF
        const link = document.createElement('a');
        link.href = data.pdf_url;
        link.download = data.filename;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        btn.textContent = '✓ PDF Downloaded!';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled = false;
        }, 2000);

      } catch (error) {
        console.error('PDF generation error:', error);
        btn.textContent = '❌ PDF Generation Failed';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled = false;
        }, 2000);
      }
    }

    // Keyboard shortcut: Ctrl+S or Cmd+S for PDF download
    window.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        generatePDF();
      }
      // Allow Ctrl+P / Cmd+P for browser print still works
    });
  </script>

</body>
</html>
